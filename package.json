{
  "name": "101",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "index",
    "html",
    "js",
    "css",
    "react",
    "vue",
    "net",
    "algo",
    "patterns",
    "swift",
    "swiftui",
    "teamlead",
    "product",
    "project",
    "marketing",
    "qa"
  ],
  "scripts": {
    "dev": "./start.sh",
    "install:all": "npm install",
    "build:pages": "node ./scripts/build-pages.mjs",
    "build:all": "npm run build --workspaces --if-present",
    "dev:index": "npm run dev -w index",
    "dev:html": "npm run dev -w html",
    "dev:js": "npm run dev -w js",
    "dev:css": "npm run dev -w css",
    "dev:react": "npm run dev -w react",
    "dev:vue": "npm run dev -w vue",
    "dev:net": "npm run dev -w net",
    "dev:algo": "npm run dev -w algo",
    "dev:patterns": "npm run dev -w patterns",
    "dev:swift": "npm run dev -w swift",
    "dev:swiftui": "npm run dev -w swiftui",
    "dev:teamlead": "npm run dev -w teamlead",
    "dev:product": "npm run dev -w product",
    "dev:project": "npm run dev -w project",
    "dev:marketing": "npm run dev -w marketing",
    "dev:qa": "npm run dev -w qa"
  }
}
